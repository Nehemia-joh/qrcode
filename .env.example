# Operations API
PORT=4000
# Comma-separated browser origins (production domain)
# CORS_ORIGINS=https://ops.silverleaf.ac.tz
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Default admin (created on first run if no users exist)
OPS_ADMIN_USERNAME=admin
OPS_ADMIN_PASSWORD=admin123

# Optional: Nehemiah QR / bus tracking MySQL (link after UI sign-off)
NEHEMIAH_DB_ENABLED=false
NEHEMIAH_DB_HOST=localhost
NEHEMIAH_DB_USER=root
NEHEMIAH_DB_PASSWORD=
NEHEMIAH_DB_NAME=school_bus_tracking

# Nehemiah PHP → forward each scan to Operations (set on PHP server)
# OPS_WEBHOOK_URL=http://localhost:4000/api/webhooks/attendance
# OPS_WEBHOOK_SECRET=dev-webhook-secret
# OPS_SCHOOL_ID=sl-main

# Optional: PHP API base if MySQL unavailable
NEHEMIAH_API_BASE_URL=

# SMS parent notifications (mock | twilio | africas_talking)
SMS_PROVIDER=mock
SMS_FEE_TEMPLATE=Silverleaf Transport: Fee balance for {name} requires attention. Please contact the school office.

# Twilio (when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Africa's Talking (when SMS_PROVIDER=africas_talking)
AT_API_KEY=
AT_USERNAME=

# Webhook: Nehemiah PHP forwards scans without MySQL on Operations side
WEBHOOK_SECRET=dev-webhook-secret
# Send parent SMS/email when scan shows is_in_credit (set false to disable)
AUTO_FEE_NOTIFY_ON_SCAN=true

# Warn admins to re-import transport .xlsx after this many days (default 30)
IMPORT_STALE_DAYS=30

# Email (mock logs to data/email-log.json, or smtp)
EMAIL_PROVIDER=mock
OPS_NOTIFY_EMAIL=operations@silverleaf.ac.tz
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Silverleaf Operations <noreply@silverleaf.ac.tz>
