# Bus QR PHP — copy to legacy/qrcode/.env (gitignored)
# Keep DB_* and SITE_URL in sync with repo-root .env (NEHEMIAH_*)

DB_HOST=localhost
DB_NAME=school_bus_tracking
DB_USER=bus_ops
DB_PASS=chance00

# Trailing slash required. Match NEHEMIAH_APP_URL + /
# Nginx:  http://localhost/school-bus-tracking/
# Dev:    http://localhost:8081/
SITE_URL=http://localhost/school-bus-tracking/

# Operations webhook + SSO (must match repo-root .env WEBHOOK_SECRET / NEHEMIAH_SSO_SECRET)
OPS_APP_URL=http://localhost:8080
OPS_WEBHOOK_URL=http://localhost:4000/api/webhooks/attendance
OPS_WEBHOOK_SECRET=dev-webhook-secret
OPS_SSO_SECRET=dev-webhook-secret
OPS_SCHOOL_ID=sl-main
OPS_WEBHOOK_ENABLED=true
